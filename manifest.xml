<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
           xsi:type="MailApp">

  <!-- Add-in Identity -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>MailMerge-Pro</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="MailMerge-Pro"/>
  <Description DefaultValue="Free mail merge for Outlook with CC, BCC, custom attachments, and mailbox selection. Send personalized bulk emails from your Excel data."/>

  <!-- Icons -->
  <IconUrl DefaultValue="https://itsjamessmith.github.io/mailmerge-pro/assets/icon-64.svg"/>
  <HighResolutionIconUrl DefaultValue="https://itsjamessmith.github.io/mailmerge-pro/assets/icon-128.svg"/>
  <SupportUrl DefaultValue="https://itsjamessmith.github.io/mailmerge-pro/"/>

  <!-- Outlook host -->
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <!-- Minimum requirement sets -->
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>

  <!-- Fallback form settings for older Outlook clients -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://itsjamessmith.github.io/mailmerge-pro/taskpane.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>
  <Rule xsi:type="ItemIs" ItemType="Message"/>

  <!-- Version Overrides for ribbon commands (Outlook 2016+, M365) -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">

        <!-- Desktop (Windows/Mac) -->
        <DesktopFormFactor>
          <FunctionFile resid="FunctionFile.Url"/>

          <!-- Appears when composing a NEW message -->
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgComposeGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="btnMailMerge">
                  <Label resid="BtnLabel"/>
                  <Supertip>
                    <Title resid="BtnLabel"/>
                    <Description resid="BtnTooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- Appears when READING a message -->
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="btnMailMergeRead">
                  <Label resid="BtnLabel"/>
                  <Supertip>
                    <Title resid="BtnLabel"/>
                    <Description resid="BtnTooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>

        <!-- Mobile form factor -->
        <MobileFormFactor>
          <FunctionFile resid="FunctionFile.Url"/>
          <ExtensionPoint xsi:type="MobileMessageReadCommandSurface">
            <Group id="mobileReadGroup">
              <Label resid="GroupLabel"/>
              <Control xsi:type="MobileButton" id="btnMobileMerge">
                <Label resid="BtnLabel"/>
                <Icon>
                  <bt:Image size="25" resid="Icon.32x32"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="48" resid="Icon.80x80"/>
                </Icon>
                <Action xsi:type="ShowTaskpane">
                  <SourceLocation resid="Taskpane.Url"/>
                </Action>
              </Control>
            </Group>
          </ExtensionPoint>
        </MobileFormFactor>

      </Host>
    </Hosts>

    <!-- Resources -->
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://itsjamessmith.github.io/mailmerge-pro/assets/icon-16.svg"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://itsjamessmith.github.io/mailmerge-pro/assets/icon-32.svg"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://itsjamessmith.github.io/mailmerge-pro/assets/icon-80.svg"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Taskpane.Url" DefaultValue="https://itsjamessmith.github.io/mailmerge-pro/taskpane.html"/>
        <bt:Url id="FunctionFile.Url" DefaultValue="https://itsjamessmith.github.io/mailmerge-pro/function-file.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Mail Merge Pro"/>
        <bt:String id="BtnLabel" DefaultValue="Mail Merge"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="BtnTooltip" DefaultValue="Send personalized bulk emails with CC, BCC, custom attachments from your Excel data."/>
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>
</OfficeApp>

